{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            // this won't be helpful without this stanza in Cargo.toml:
            //     [profile.bench]
            //     debug = true
            //     opt-level = 1
            // but don't leave it there for actual timing runs
            "type": "lldb",
            "request": "launch",
            "name": "rust 'rand' bench",
            "cargo": {
                "args": ["bench", "--no-run", "--manifest-path", "rust/Cargo.toml", "--bench", "rand", "--features", "alloc"],
                "filter": { "name": "rand", "kind": "bench" }
            },
            "cwd": "${workspaceFolder}/rust"
        },
        {
            "name": "tindalwic_test __main__",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}/python",
            "module": "tindalwic_test",
            "args": ["--failures=../zzz", "--loops=4000"],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
